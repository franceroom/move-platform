# MOVE platform — variables d'environnement (copier en .env, ne jamais committer .env)
NODE_ENV=development
PORT=3000
SESSION_SECRET=change-me

# Base de données PostgreSQL (Render > move-db > Internal Database URL en prod)
DATABASE_URL=

# Stripe (mode TEST d'abord — clés saisies par Elhadji uniquement)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Caution (portage du module existant — compte Stripe cautions)
DEPOSIT_STRIPE_TEST_KEY=
DEPOSIT_STRIPE_KEY=
DEPOSIT_WEBHOOK_SECRET=
DEPOSIT_LIVE=false

# iCal (portage du module existant)
ICAL_SYNC_TOKEN=
ICAL_SYNC_INTERVAL_HOURS=3

# Mapbox (fond de carte)
MAPBOX_TOKEN=
