<%- include("../../partials/head", { title: "Admin" }) %>
<section class="admin-page">
  <div class="admin-head">
    <h1>Annonces</h1>\n    <nav class="admin-nav"><a href="/admin">Annonces</a> · <a href="/admin/demandes">Demandes</a> · <a href="/admin/proprietaires">Candidatures proprio</a></nav>
    <div>
      <a class="btn btn-primary" href="/admin/annonces/new">+ Nouvelle annonce</a>
      <form method="post" action="/deconnexion" style="display:inline"><button class="btn btn-ghost">Se déconnecter</button></form>
    </div>
  </div>
  <table class="admin-table">
    <thead><tr><th>ID</th><th>Titre</th><th>Ville</th><th>Catégorie</th><th>Loyer</th><th>Statut</th><th></th></tr></thead>
    <tbody>
      <% for (const r of rows) { %>
      <tr>
        <td><%= r.id %></td>
        <td><a href="/admin/annonces/<%= r.id %>/edit"><%= r.title_fr %></a></td>
        <td><%= r.ville %></td>
        <td><%= r.category %><%= r.subcategory ? " / " + r.subcategory : "" %></td>
        <td><%= euros(r.loyer_mensuel_cts) %> €</td>
        <td><span class="pill pill-<%= r.status %>"><%= r.status %></span></td>
        <td>
          <form method="post" action="/admin/annonces/<%= r.id %>/status">
            <% if (r.status !== "published") { %>
              <button class="btn btn-small" name="status" value="published">Publier</button>
            <% } else { %>
              <button class="btn btn-small" name="status" value="draft">Dépublier</button>
            <% } %>
          </form>
        </td>
      </tr>
      <% } %>
    </tbody>
  </table>
</section>
<%- include("../../partials/foot") %>
