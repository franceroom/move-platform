<%- include("../partials/head", { title: t("nav.login") }) %>
<section class="content-page narrow">
  <h1><%= t("nav.login") %></h1>
  <% if (error) { %><p class="error"><%= error %></p><% } %>
  <form method="post" action="/connexion" class="stack">
    <input type="hidden" name="next" value="<%= next %>">
    <label><%= t("login.email") %><input type="email" name="email" required autocomplete="email"></label>
    <label><%= t("login.password") %><input type="password" name="password" required autocomplete="current-password"></label>
    <button class="btn btn-primary" type="submit"><%= t("nav.login") %></button>
    <p class="muted small"><%= t("login.noAccount") %> <a href="/inscription?next=<%= encodeURIComponent(next) %>"><u><%= t("nav.signup") %></u></a></p>
  </form>
</section>
<%- include("../partials/foot") %>
