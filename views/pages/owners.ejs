<%- include("../partials/head", { title: t("owners.title") }) %>
<section class="hero small">
  <div class="hero-inner">
    <h1><%= t("owners.title") %></h1>
    <p><%= t("owners.subtitle") %></p>
  </div>
</section>
<section class="content-page">
  <div class="cards">
    <div class="card"><h3>1. <%= t("owners.step1.title") %></h3><p><%= t("owners.step1.body") %></p></div>
    <div class="card"><h3>2. <%= t("owners.step2.title") %></h3><p><%= t("owners.step2.body") %></p></div>
    <div class="card"><h3>3. <%= t("owners.step3.title") %></h3><p><%= t("owners.step3.body") %></p></div>
  </div>
  <h2 id="candidater" style="margin-top:36px"><%= t("owners.form.title") %></h2>
  <% if (sent) { %><p class="success"><%= t("owners.form.sent") %></p><% } %>
  <% if (errors) { %><p class="error"><%= errors %></p><% } %>
  <form method="post" action="/confier-mon-bien" class="stack" style="max-width:520px">
    <label><%= t("owners.form.name") %> *<input name="nom" required value="<%= form.nom || "" %>"></label>
    <label>Email *<input type="email" name="email" required value="<%= form.email || "" %>"></label>
    <label><%= t("owners.form.phone") %><input name="phone" value="<%= form.phone || "" %>"></label>
    <label><%= t("owners.form.city") %><input name="ville" value="<%= form.ville || "" %>"></label>
    <label><%= t("owners.form.message") %><textarea name="message" rows="5" placeholder="<%= t("owners.form.messagePh") %>"><%= form.message || "" %></textarea></label>
    <button class="btn btn-primary" type="submit"><%= t("owners.form.submit") %></button>
    <p class="muted small"><%= t("owners.form.note") %></p>
  </form>
</section>
<%- include("../partials/foot") %>
